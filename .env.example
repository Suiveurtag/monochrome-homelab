# Monochrome self-hosted server
MONOCHROME_SERVER_HOST=127.0.0.1
MONOCHROME_SERVER_PORT=8790
MONOCHROME_SERVER_DATA=.storage/self-hosted

# Auth is a placeholder until the admin approval checkpoints are implemented.
MONOCHROME_AUTH_REQUIRED=true
MONOCHROME_AUTH_APPROVAL_REQUIRED=true
MONOCHROME_AUTH_PROVIDER=placeholder

# Local upload prototype server
MONOCHROME_UPLOAD_PORT=8789
MONOCHROME_UPLOAD_STORAGE=.storage/server-uploads
MONOCHROME_UPLOAD_MAX_BYTES=262144000
